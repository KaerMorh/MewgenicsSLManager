{
  "$schema": "https://raw.githubusercontent.com/nicira/nicira/main/schema.json",
  "productName": "MewgenicsSLManager",
  "version": "1.5.0",
  "identifier": "com.mewgenicsslmanager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MewgenicsSLManager",
        "width": 1024,
        "height": 800,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "both"
      },
      "wix": {
        "template": "wix/main.wxs"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NzExNjc4MzU2RUZFNDIKUldSQy9tNDFlQlp4NVNwdlZkN0EycmdIV1ZMVFZJb3crclRtbmp6ZXc1ZHMwV1VUV21DSWFMd3QK",
      "endpoints": [
        "https://github.com/KaerMorh/MewgenicsSLManager/releases/latest/download/latest.json"
      ]
    }
  }
}
