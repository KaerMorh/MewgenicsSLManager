{
  "$schema": "https://raw.githubusercontent.com/nicira/nicira/main/schema.json",
  "productName": "MeowLoader",
  "version": "1.2.0",
  "identifier": "com.meowloader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MeowLoader",
        "width": 1024,
        "height": 800,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
